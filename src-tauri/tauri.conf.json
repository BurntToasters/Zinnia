{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zinnia",
  "version": "0.4.0",
  "identifier": "run.rosie.zinnia",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zinnia",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://api.github.com https://github.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app",
      "nsis",
      "appimage",
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "externalBin": [
      "binaries/7z"
    ],
    "fileAssociations": [
      {
        "ext": [
          "7z"
        ],
        "mimeType": "application/x-7z-compressed",
        "description": "7-Zip Archive"
      },
      {
        "ext": [
          "zip"
        ],
        "mimeType": "application/zip",
        "description": "ZIP Archive"
      },
      {
        "ext": [
          "tar"
        ],
        "mimeType": "application/x-tar",
        "description": "TAR Archive"
      },
      {
        "ext": [
          "gz",
          "tgz"
        ],
        "mimeType": "application/gzip",
        "description": "Gzip Archive"
      },
      {
        "ext": [
          "bz2",
          "tbz2"
        ],
        "mimeType": "application/x-bzip2",
        "description": "Bzip2 Archive"
      },
      {
        "ext": [
          "xz",
          "txz"
        ],
        "mimeType": "application/x-xz",
        "description": "XZ Archive"
      },
      {
        "ext": [
          "rar"
        ],
        "mimeType": "application/vnd.rar",
        "description": "RAR Archive"
      }
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/BurntToasters/zinnia/releases/latest/download/latest-{{target}}-{{arch}}.json",
        "https://github.com/BurntToasters/zinnia/releases/download/v{{current_version}}/latest-{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0NzYyNzkzRUJDRTgwNDIKUldSQ2dNN3JreWQyRkxPZG1haUJ1WlJjT3JFTGJnNktuOWxETU1Ia1BkTjIwNDc1Vk90aEN0QWIK"
    }
  }
}
