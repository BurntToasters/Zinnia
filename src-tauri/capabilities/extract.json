{
  "$schema": "https://schema.tauri.app/capabilities/2",
  "identifier": "extract-window",
  "description": "Permissions for extract-only windows",
  "windows": [
    "extract-*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "process:default",
    "shell:allow-open"
  ]
}
