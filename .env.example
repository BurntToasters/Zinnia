# GitHub personal access token (repo scope) — used to create releases & upload assets
GH_TOKEN=

# GPG key ID / fingerprint for signing release artifacts
GPG_KEY_ID=

# GPG passphrase for non-interactive (CI) signing
GPG_PASSPHRASE=

# Override repo owner/name (defaults to BurntToasters/chrysanthemum)
# GH_REPO_OWNER=BurntToasters
# GH_REPO_NAME=chrysanthemum
