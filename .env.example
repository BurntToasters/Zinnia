# GitHub personal access token (repo scope) — used to create releases & upload assets
GH_TOKEN=

# GPG key ID / fingerprint for signing release artifacts
GPG_KEY_ID=

# GPG passphrase for non-interactive (CI) signing
GPG_PASSPHRASE=

# Tauri updater signing (from `tauri signer generate`):
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# macOS codesigning & notarization (used by Tauri automatically):
# Certificate identity from Keychain (e.g. "Developer ID Application: Name (TEAMID)")
APPLE_SIGNING_IDENTITY=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
SSH_USER_PWD=

# Optional: mirror cleaned `release/` artifacts to another folder after finalize step
# AFTER_PACK_LOC=/absolute/path/to/output

# Override repo owner/name (defaults to BurntToasters/zinnia)
# GH_REPO_OWNER=BurntToasters
# GH_REPO_NAME=zinnia
